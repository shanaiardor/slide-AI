{
  "manifest_version": 3,
  "name": "滑词问 AI",
  "version": "0.2.1",
  "description": "在任意网页中滑词后直接向 AI 提问，并支持继续追问。",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "滑词问 AI",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/shared.js",
        "src/content/markdown.js",
        "src/content/selection.js",
        "src/content/ui.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/markdown-runtime.bundle.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
